spring:
  application:
    name: youkang-file-splitter
  main:
    web-application-type: none
    banner-mode: "off"

splitter:
  # Seq 入口目录：扫描该目录下的所有文件夹作为订单
  inbox-dir: /data/youkang/Seq
  # 结果目录：拆分后的 Bam/Var/Sequence/QC 输出位置
  result-dir: /data/youkang/Result
  # 归档目录：处理完成后的原始订单归档
  archive-dir: /data/youkang/archive
  scan-cron: "0 */1 * * * ?"
  ready-check-interval-seconds: 10
  sqlite-path: /data/youkang/splitter/records.db
  delete-after-archive: false
  retry-times: 3
  retry-interval-ms: 2000

logging:
  file:
    name: /data/youkang/splitter/logs/splitter.log
  logback:
    rollingpolicy:
      max-file-size: 50MB
      max-history: 30
      total-size-cap: 5GB
  level:
    root: INFO
    com.youkang.splitter: INFO
